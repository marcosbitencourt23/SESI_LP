#include <stdio.h>

int main() {
    float a, b;
    char op;

    scanf("%f %f", &a, &b);
    scanf(" %c", &op);

    if (op == '+') {
        printf("%.2f\n", a + b);
    } else if (op == '-') {
        printf("%.2f\n", a - b);
    } else if (op == '*') {
        printf("%.2f\n", a * b);
    } else if (op == '/') {
        printf("%.2f\n", a / b);
    }

    return 0;
}