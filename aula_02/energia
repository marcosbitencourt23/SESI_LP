#include <stdio.h>

int main() {
    int consumo;
    float total;

    scanf("%d", &consumo);

    if (consumo <= 100) {
        total = consumo * 0.50;
    } else if (consumo <= 200) {
        total = consumo * 0.75;
    } else {
        total = consumo * 1.00;
    }

    printf("Total: %.2f\n", total);

    return 0;
}