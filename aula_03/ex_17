#include <stdio.h>
int main() {
    int idade, soma = 0, cont = 0;
    while(1) {
        printf("Idade (0 para sair): ");
        scanf("%d", &idade);
        if(idade == 0) break;
        soma += idade;
        cont++;
    }
    if(cont > 0) printf("Média: %.2f\n", (float)soma/cont);
    return 0;
}